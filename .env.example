# =============================================================================
# AI Innovation Hub — Backend Environment Variables
# Copie para .env e preencha os valores antes de rodar
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=innovation_hub
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- Database URL ---
# Com Docker: host é "db" (nome do serviço no docker-compose)
# Sem Docker: ajuste host/porta conforme seu PostgreSQL local
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/innovation_hub

# --- JWT ---
# OBRIGATÓRIO: gere um valor único com:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=TROQUE_POR_UMA_CHAVE_SEGURA_E_ALEATORIA
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# --- HuggingFace (opcional) ---
# Token GRATUITO em: https://huggingface.co/settings/tokens → New token (read)
# Se vazio, a categorização por IA retorna "Other" — ideias funcionam normalmente
HUGGINGFACE_TOKEN=

# --- CORS ---
# Origens permitidas separadas por vírgula
# Adicione o endereço do frontend em produção
CORS_ORIGINS=http://localhost:3000
